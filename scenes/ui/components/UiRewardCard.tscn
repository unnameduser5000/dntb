[gd_scene format=3]

[node name="UiRewardCard" type="Button"]
custom_minimum_size = Vector2(200, 132)
size_flags_horizontal = 3
theme_type_variation = &"ActionCard"
alignment = 0
text = ""

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2
theme_override_constants/margin_left = 14
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 14
theme_override_constants/margin_bottom = 12

[node name="Content" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Title" type="Label" parent="Margin/Content"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"BattleSectionTitle"
autowrap_mode = 3
horizontal_alignment = 1
text = "奖励名称"

[node name="Body" type="Label" parent="Margin/Content"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"ScreenSubtitle"
autowrap_mode = 3
horizontal_alignment = 1
vertical_alignment = 1
size_flags_vertical = 3
text = "奖励描述"
