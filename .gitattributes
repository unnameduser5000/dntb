# Normalize EOL for text files.
* text=auto eol=lf

# Godot text resources.
*.gd text eol=lf linguist-language=GDScript
*.tscn text eol=lf
*.tres text eol=lf
*.godot text eol=lf
*.import text eol=lf
*.uid text eol=lf
# Documentation and repository metadata.
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ogg binary
*.wav binary
*.mp3 binary
*.flac binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.aseprite binary
*.psd binary
